@model Organization
@{
    ViewData["Title"] = "Delete Organization";
}

<h1>Delete Organization</h1>
<h3>Are you sure you want to delete this?</h3>
<hr />
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ContactEmail)</dt>
    <dd class="col-sm-9">@Model.ContactEmail</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsVerified)</dt>
    <dd class="col-sm-9">@(Model.IsVerified ? "Yes" : "No")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="OrganizationId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
