@model Skill
@{
    ViewData["Title"] = "Delete Skill";
}

<h1>Delete Skill</h1>
<h3>Are you sure you want to delete this?</h3>
<hr />
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Category)</dt>
    <dd class="col-sm-9">@Model.Category</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.RequiresCertification)</dt>
    <dd class="col-sm-9">@(Model.RequiresCertification ? "Yes" : "No")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="SkillId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
