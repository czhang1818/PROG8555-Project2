@model Coordinator
@{
    ViewData["Title"] = "Coordinator Details";
}

<h1>Coordinator Details</h1>
<hr />
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.JobTitle)</dt>
    <dd class="col-sm-9">@Model.JobTitle</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PhoneNumber)</dt>
    <dd class="col-sm-9">@Model.PhoneNumber</dd>

    <dt class="col-sm-3">Organization</dt>
    <dd class="col-sm-9">@Model.Organization?.Name</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.CoordinatorId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
