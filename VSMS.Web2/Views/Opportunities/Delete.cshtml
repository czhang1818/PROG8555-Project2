@model Opportunity
@{
    ViewData["Title"] = "Delete Opportunity";
}

<h1>Delete Opportunity</h1>
<h3>Are you sure you want to delete this?</h3>
<hr />
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Title)</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Organization</dt>
    <dd class="col-sm-9">@Model.Organization?.Name</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EventDate)</dt>
    <dd class="col-sm-9">@Model.EventDate.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="OpportunityId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
