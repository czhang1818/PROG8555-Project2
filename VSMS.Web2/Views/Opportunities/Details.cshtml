@model Opportunity
@{
    ViewData["Title"] = "Opportunity Details";
}

<h1>Opportunity Details</h1>
<hr />
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Title)</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Organization</dt>
    <dd class="col-sm-9">@Model.Organization?.Name</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EventDate)</dt>
    <dd class="col-sm-9">@Model.EventDate.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Location)</dt>
    <dd class="col-sm-9">@Model.Location</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.MaxVolunteers)</dt>
    <dd class="col-sm-9">@Model.MaxVolunteers</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.OpportunityId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
