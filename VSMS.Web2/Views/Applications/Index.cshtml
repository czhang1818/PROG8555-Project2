@model PaginatedList<Application>
@{
    ViewData["Title"] = "Applications";
}

<h1>Applications</h1>
<p><a asp-action="Create" class="btn btn-primary">Create New</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Volunteer</th>
            <th>Opportunity</th>
            <th>@Html.DisplayNameFor(model => model.First().SubmissionDate)</th>
            <th>@Html.DisplayNameFor(model => model.First().Status)</th>
            <th>@Html.DisplayNameFor(model => model.First().CreatedByUserId)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Volunteer?.Name</td>
                <td>@item.Opportunity?.Title</td>
                <td>@item.SubmissionDate.ToString("yyyy-MM-dd")</td>
                <td>@item.Status</td>
                <td>@item.CreatedByUserId</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.AppId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.AppId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.AppId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" class="page-link">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a asp-action="Index" asp-route-pageNumber="@i" class="page-link">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" class="page-link">Next</a>
            </li>
        </ul>
    </nav>
}
