@model List<AdminRoleViewModel>
@{
    ViewData["Title"] = "Manage Roles";
}

<h1>Manage Roles</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New Role</a>
    <a asp-action="Assign" class="btn btn-outline-primary">Assign Roles</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Role Name</th>
            <th>Users in Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
        {
            <tr>
                <td>@role.Name</td>
                <td>@role.UserCount</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
