@model Microsoft.AspNetCore.Identity.IdentityRole<Guid>
@{
    ViewData["Title"] = "Delete Role";
}

<h1>Delete Role</h1>
<h3>Are you sure you want to delete this role?</h3>
<hr />
<dl class="row">
    <dt class="col-sm-3">Role Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Users in Role</dt>
    <dd class="col-sm-9">@ViewData["UserCount"]</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
